# ==================== 数据库配置（来自你的 DB_*） ====================
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=replace_me
DB_DATABASE=customer_blog

# Prisma 使用的标准连接串（建议通过脚本由 DB_* 组合）
DATABASE_URL="mysql://root:replace_me@127.0.0.1:3306/customer_blog"

# ==================== 后台登录配置 ====================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_me
AUTH_SECRET=replace_with_long_random_string

# ==================== 应用配置 ====================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
UPLOAD_DIR=public/uploads
